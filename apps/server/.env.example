# Database
DATABASE_URL=postgresql://username:password@localhost:5432/mydatabase

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# NextAuth (for JWT validation)
NEXTAUTH_SECRET=your-random-secret-here-generate-with-openssl-rand-base64-32

# AI — webhook payload analysis (OpenAI-compatible API)
# Use a key from https://platform.openai.com/account/api-keys (starts with sk-proj- or sk-).
# OpenRouter keys (sk-or-v1-...) require a base URL — do not leave OPENAI_BASE_URL empty:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
# Optional: proxy / OpenRouter / Azure OpenAI-style base URL
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
